# Copy to Makefile.local (gitignored) and edit as needed.

# Override target chip for `make set-target`
# TARGET ?= esp32p4

# Serial port for `make flash`, `make monitor`, `make flash-monitor`,
# `make erase-flash`. Can also be passed on the command line:
#   make flash PORT=/dev/ttyACM1
# PORT ?= /dev/ttyACM0

menu "Tab5 terminal"

    config TAB5_MAX_PROFILES
        int "Maximum on-device connection profiles"
        range 1 16
        default 4
        help
            Profiles are stored in NVS namespace "conn" and edited on
            the device. Each slot holds one (protocol, host, port,
            user, auth, password) tuple. On a virgin device profile 0
            is seeded from the legacy CONFIG_TAB5_SSH_* /
            CONFIG_TAB5_TELNET_* values; afterwards NVS is the source
            of truth and those Kconfig values are ignored at runtime.


    config TAB5_UART_INPUT_ENABLED
        bool "Enable external UART byte-input source"
        default y
        help
            When enabled, the terminal also reads bytes from a UART
            peripheral (in addition to USB-Serial-JTAG) and feeds them
            into the VT100 core. Default pins target Tab5 Port-A.

    config TAB5_UART_INPUT_PORT
        int "UART port index"
        depends on TAB5_UART_INPUT_ENABLED
        default 1
        range 0 2
        help
            UART_NUM_x to use. UART_NUM_0 is normally the console UART
            on chips that route the console there; on ESP32-P4 the
            console is USB-Serial-JTAG so UART_NUM_0 is free.

    config TAB5_UART_INPUT_TX_GPIO
        int "UART TX GPIO"
        depends on TAB5_UART_INPUT_ENABLED
        default 54
        help
            GPIO used as UART TX. Tab5 Port-A SCL is GPIO 54.

    config TAB5_UART_INPUT_RX_GPIO
        int "UART RX GPIO"
        depends on TAB5_UART_INPUT_ENABLED
        default 53
        help
            GPIO used as UART RX. Tab5 Port-A SDA is GPIO 53.

    config TAB5_UART_INPUT_BAUD
        int "Baud rate"
        depends on TAB5_UART_INPUT_ENABLED
        default 115200

    config TAB5_USB_HID_INPUT_ENABLED
        bool "Enable USB HID keyboard input"
        default y
        help
            When enabled, the app installs the USB host stack and the
            HID class driver. A USB keyboard plugged into the Tab5
            USB-A port acts as another byte-input source — its keys
            flow through the same path as USB-JTAG / UART (cooked
            filter when no remote connection, or directly to SSH /
            Telnet when one is up).

    config TAB5_KEYBOARD_INPUT_ENABLED
        bool "Enable Tab5 Keyboard (ExtPort1, I2C)"
        default n
        help
            M5Stack Tab5 clip-on keyboard wired to ExtPort1 (I2C addr
            0x6D, INT=GPIO50). Bytes flow through the same path as the
            other input sources. Pulls in M5UnitUnified + M5Unit-KEYBOARD
            — see main/idf_component.yml. Set to =y here OR in
            sdkconfig.defaults.local once you have the keyboard plugged in.

    config TAB5_KEYBOARD_I2C_SDA
        int "Tab5 Keyboard SDA GPIO"
        depends on TAB5_KEYBOARD_INPUT_ENABLED
        default 0
        help
            Tab5 ExtPort1 J9 pin 7 — GPIO0 — is the SDA on the keyboard
            connector. Override if the wiring differs from the stock
            Tab5 layout.

    config TAB5_KEYBOARD_I2C_SCL
        int "Tab5 Keyboard SCL GPIO"
        depends on TAB5_KEYBOARD_INPUT_ENABLED
        default 1

    config TAB5_KEYBOARD_INT_GPIO
        int "Tab5 Keyboard INT GPIO"
        depends on TAB5_KEYBOARD_INPUT_ENABLED
        default 50
        help
            ExtPort1 J9 pin 10. Used in INT-driven mode so update()
            only does I2C work when the firmware has events pending.

    config TAB5_USB_SERIAL_BAUD
        int "USB-serial default baud rate"
        default 115200
        range 300 921600
        help
            Baud rate for the UsbSerialConnection backend (FTDI host).
            Used when a profile with proto=UsbSerial is selected. 8N1
            line format. Per-profile baud is a follow-up.

    menu "Wi-Fi"

        config TAB5_WIFI_ENABLED
            bool "Enable Wi-Fi station"
            default n
            help
                When enabled, the app brings up the ESP32-C6 Wi-Fi
                co-processor and joins the AP configured below.
                Requires the matching C6 firmware to be flashed
                (see wifi_c6_fw/ in M5Tab5-UserDemo).

        config TAB5_WIFI_SSID
            string "SSID"
            depends on TAB5_WIFI_ENABLED
            default ""

        config TAB5_WIFI_PSK
            string "WPA2 pre-shared key"
            depends on TAB5_WIFI_ENABLED
            default ""

        config TAB5_WIFI_CONNECT_TIMEOUT_S
            int "Initial connect timeout (seconds)"
            depends on TAB5_WIFI_ENABLED
            default 20

    endmenu

    menu "Telnet"

        config TAB5_TELNET_ENABLED
            bool "Enable Telnet client"
            default n
            depends on TAB5_WIFI_ENABLED
            help
                Plain TCP + RFC 854 telnet. The app picks this only if
                SSH is disabled (or SSH start failed) — SSH takes
                priority when both are enabled.

        config TAB5_TELNET_HOST
            string "Server host"
            depends on TAB5_TELNET_ENABLED
            default ""

        config TAB5_TELNET_PORT
            int "Server port"
            depends on TAB5_TELNET_ENABLED
            default 23
            range 1 65535

        config TAB5_TELNET_RX_TASK_STACK
            int "telnet_task stack size (bytes)"
            depends on TAB5_TELNET_ENABLED
            default 6144
            range 4096 32768

    endmenu

    menu "SSH"

        config TAB5_SSH_ENABLED
            bool "Enable SSH client"
            default n
            depends on TAB5_WIFI_ENABLED
            help
                When enabled and Wi-Fi has come up, the app opens an
                SSH shell session to the configured server, renders
                the remote pty on the LCD, and forwards locally-typed
                bytes (USB-Serial-JTAG + UART) to the remote.

        config TAB5_SSH_HOST
            string "Server host"
            depends on TAB5_SSH_ENABLED
            default ""
            help
                Hostname or dotted-quad IPv4 address.

        config TAB5_SSH_PORT
            int "Server port"
            depends on TAB5_SSH_ENABLED
            default 22
            range 1 65535

        config TAB5_SSH_USER
            string "Username"
            depends on TAB5_SSH_ENABLED
            default ""

        config TAB5_SSH_PASSWORD
            string "Password"
            depends on TAB5_SSH_ENABLED
            default ""
            help
                Password for password authentication. Used as a fallback
                if TAB5_SSH_PUBKEY_AUTH is enabled and the key step fails,
                or as the primary auth method when public-key auth is off.

        config TAB5_SSH_PUBKEY_AUTH
            bool "Try public-key authentication first"
            depends on TAB5_SSH_ENABLED
            default n
            help
                Embed the PEM private key at main/keys/id_rsa into the
                firmware and use it via libssh2_userauth_publickey_frommemory
                before falling back to password auth. Generate the key with:
                    ssh-keygen -m PEM -t rsa -b 2048 -f main/keys/id_rsa
                The keys/ directory is gitignored; do NOT commit private keys.
                Authorise the matching .pub on the remote with ssh-copy-id.

        config TAB5_SSH_KEY_PASSPHRASE
            string "Private-key passphrase (if encrypted)"
            depends on TAB5_SSH_PUBKEY_AUTH
            default ""

        config TAB5_SSH_RX_TASK_STACK
            int "ssh_task stack size (bytes)"
            depends on TAB5_SSH_ENABLED
            default 8192
            range 4096 32768

    endmenu

endmenu
